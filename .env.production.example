# Firemní pwpush účet — všechny pushe se vytvoří pod tímto účtem
# a budou viditelné v dashboardu pro všechny zaměstnance.
#
# Jak získat token:
#   1. Spusťte: docker compose up pwpush -d
#   2. Otevřete http://adresa-serveru:5100
#   3. Zaregistrujte účet a přejděte na Profile → API Access
#   4. Zkopírujte API Token a doplňte níže
#
# Poznámka: PWPUSH_API_BASE není potřeba — Docker Compose ho nastavuje automaticky.

PWPUSH_EMAIL=admin@svoboda.cz
PWPUSH_TOKEN=vas_api_token_z_pwpush
